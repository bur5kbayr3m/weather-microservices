{
  "id": null,
  "uid": "weather-overview",
  "title": "Weather Microservices Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Gateway Request Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{job='api-gateway'}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Errors",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_exceptions_total[1m]))",
          "legendFormat": "exceptions/s"
        }
      ]
    }
  ]
}
